# Copy this file to .env in this same directory and fill in what you
# want to change. .env is git-ignored - never commit real values.

# How often to poll, in minutes. Enforced minimum is 20 regardless of
# what you set here.
AGASTYA_POLL_INTERVAL_MINUTES=30

# Where to write the local jobs snapshot. Defaults to your Downloads
# folder if unset.
# AGASTYA_LOCAL_OUTPUT_PATH=C:\Users\you\Downloads\agastya-jobs.json

# Set to "false" to disable desktop popups.
AGASTYA_DESKTOP_NOTIFICATIONS=true

# Optional Telegram notifications - same bot/chat as the GitHub Actions
# workflow uses, see README "Telegram notifications" section.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Only change this if you've forked the repo under a different
# owner/name - it's where alerts.json / jobs.json are fetched from.
# AGASTYA_LIVE_DATA_BASE_URL=https://raw.githubusercontent.com/<owner>/<repo>/main/frontend/public/data
